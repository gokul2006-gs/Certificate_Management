# Render (backend) — copy these into your Render service Environment variables.

DEBUG=False
SECRET_KEY=replace-with-a-long-random-secret

ALLOWED_HOSTS=.onrender.com,smart-certificate-management-and.onrender.com

# Your primary Vercel frontend URL (no trailing slash)
FRONTEND_BASE_URL=https://your-app.vercel.app

# Optional: extra preview/production origins, comma-separated
# FRONTEND_ALLOWED_ORIGINS=https://your-app.vercel.app,https://your-app-git-branch.vercel.app

# Database (Render/Railway provides DATABASE_URL)
# DATABASE_URL=postgres://...
